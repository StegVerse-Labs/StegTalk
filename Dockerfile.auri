FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8080 \
    AURI_PROVIDER_MODE=disabled \
    AURI_PROVIDER_ID=provider:disabled

WORKDIR /app
COPY pyproject.toml /app/
COPY src /app/src
COPY auri /app/auri
RUN pip install --no-cache-dir .

EXPOSE 8080
USER 65532:65532
CMD ["python", "-m", "stegtalk.auri"]
