{
  "schema_version": "1.0.0",
  "entity_id": "stegverse:auri",
  "activation_level": "AURI-L1",
  "default_posture": "fail_closed",
  "permitted": {
    "conversation": true,
    "interpret_approved_context": true,
    "prepare_change_requests": true,
    "prepare_commitment_candidates": true,
    "request_readiness_evaluation": true,
    "request_authority_evaluation": true,
    "explain_results": true,
    "emit_advisory_receipt_candidates": true
