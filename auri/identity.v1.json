    "admissibility_provider": "StegVerse-Labs/StegCore",
    "continuity_provider": "StegID_or_Continuity_receipt_governance",
    "model_output_classification": "untrusted_candidate_until_evaluated"
  },
  "containment": {
    "revocable": true,
    "quarantinable": true,
    "provider_disablement_required": true,
    "session_isolation_required": true,
    "known_good_state_required": true
  },
  "activation_requirements": {
    "identity_verified": false,
    "runtime_deployed": false,
    "provider_adapter_verified": false,
    "stegcore_gateway_verified": false,
    "continuity_receipts_verified": false,
    "revocation_test_passed": false,
    "end_to_end_proof_passed": false
  }
